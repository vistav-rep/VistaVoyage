# Frontend environment variables for Vite
# Prefix with VITE_ to expose to client-side code

# Backend API base URL
VITE_API_URL=http://localhost:5000/api

# Socket server URL (same host/port as backend by default)
VITE_SOCKET_URL=http://localhost:5000

# Asset base URL used to load uploaded images (no trailing slash)
VITE_ASSET_BASE_URL=http://localhost:5000

# Example: VITE_API_URL=https://api.yourdomain.com/api
